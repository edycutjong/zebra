# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
**/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Environment variables override
!.env.example

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# Lighthouse
.lighthouseci/


# Cargo / Rust build outputs
target/
**/target/

# Coverage outputs
.nyc_output/

# SWC compiler cache
.swc/

# Generated assets and designs
assets/
_shared/
_designs/

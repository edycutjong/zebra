# Zebra Environment Variables Example

# Supabase Configurations
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Stellar Network Config
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Soroban Contract Addresses
NEXT_PUBLIC_TREASURY_CONTRACT_ID=CB3JXP...Z5A3
# v3 multi-currency payroll contract (verify_mc_proof / release_payroll_v3)
NEXT_PUBLIC_ZEBRA_MC_CONTRACT_ID=CB3JXP...MC3A
